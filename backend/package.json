{
  "name": "gaslink-backend",
  "version": "1.0.0",
  "description": "GasLink Rwanda Backend API",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "db:seed": "ts-node src/scripts/seed.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "lpg",
    "delivery",
    "rwanda",
    "gaslink"
  ],
  "author": "GasLink Rwanda",
  "license": "MIT",
  "dependencies": {
